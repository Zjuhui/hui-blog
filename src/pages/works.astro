---
import BaseLayout from "../layouts/BaseLayout.astro";
import GlassHeader from "../components/GlassHeader.astro";
---

<BaseLayout title="Works | 珲">
  <GlassHeader />
  <main class="page-shell simple-page glass">
    <p class="quiet-label">Works</p>
    <h1>作品集 / Portfolio</h1>
    <p>这里会放项目、设计、论文图、开源实验和阶段性成果。</p>
  </main>
</BaseLayout>

<style>
  .simple-page {
    margin-top: 64px;
    padding: clamp(32px, 7vw, 72px);
    border-radius: var(--radius-xl);
  }

  h1 {
    margin: 10px 0 0;
    font-size: clamp(36px, 6vw, 72px);
    line-height: 1.04;
  }

  p:last-child {
    max-width: 720px;
    color: var(--muted);
    font-size: 18px;
  }
</style>

