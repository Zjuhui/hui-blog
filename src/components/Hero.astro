---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
---

<section class="hero page-shell">
  <div class="hero-card glass">
    <div class="hero-meta">
      <span>珲</span>
      <p>Blog: In AI Era, What can I do?</p>
    </div>
    <h1 class="text-balance">If You Are Nothing Without AI, Then You Shouldn't Have It!</h1>
    <p class="hero-subtitle text-balance">
      科研、生活与作品集的长期记录场。先写，再生长。
    </p>
    <div class="hero-actions" aria-label="Primary actions">
      <a class="primary-action" href={`${base}posts/why-this-blog/`}>Read Week 01</a>
      <a class="secondary-action" href={`${base}archive/`}>Open archive</a>
    </div>
  </div>

  <aside class="portrait glass" aria-label="Blog identity">
    <div class="orb">珲</div>
    <p>Research / Life / Works</p>
  </aside>
</section>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    align-items: stretch;
    gap: 22px;
    padding: 84px 0 28px;
  }

  .hero-card {
    position: relative;
    overflow: hidden;
    min-height: 560px;
    padding: clamp(36px, 6vw, 74px);
    border-radius: var(--radius-xl);
  }

  .hero-card::before {
    position: absolute;
    inset: 1px;
    border-radius: calc(var(--radius-xl) - 1px);
    background:
      radial-gradient(circle at 78% 18%, rgba(255, 255, 255, 0.88), transparent 24%),
      radial-gradient(circle at 20% 92%, rgba(0, 122, 255, 0.12), transparent 34%);
    pointer-events: none;
    content: "";
  }

  .hero-card > * {
    position: relative;
    z-index: 1;
  }

  .hero-meta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 54px;
    padding: 8px 14px 8px 8px;
    border: 1px solid rgba(255, 255, 255, 0.74);
    border-radius: var(--radius-pill);
    background: rgba(255, 255, 255, 0.42);
  }

  .hero-meta span {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #fff7ee;
    background: var(--seal);
    font-family: "STXingkai", "KaiTi", "Noto Serif SC", serif;
    font-size: 22px;
  }

  .hero-meta p {
    margin: 0;
    color: var(--muted);
    font-size: 13px;
    font-weight: 650;
  }

  h1 {
    max-width: 900px;
    margin: 0;
    font-size: clamp(48px, 8vw, 112px);
    font-weight: 800;
    letter-spacing: 0;
    line-height: 0.94;
  }

  .hero-subtitle {
    max-width: 680px;
    margin: 28px 0 0;
    color: var(--muted);
    font-size: clamp(18px, 2vw, 23px);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 44px;
  }

  .primary-action,
  .secondary-action {
    display: inline-grid;
    place-items: center;
    min-height: 48px;
    padding: 12px 22px;
    border-radius: var(--radius-pill);
    font-weight: 750;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease;
  }

  .primary-action {
    color: white;
    background: #111317;
    box-shadow: 0 18px 36px rgba(17, 19, 23, 0.18);
  }

  .secondary-action {
    border: 1px solid rgba(17, 19, 23, 0.1);
    background: rgba(255, 255, 255, 0.48);
  }

  .primary-action:hover,
  .secondary-action:hover {
    transform: translateY(-2px);
  }

  .portrait {
    display: grid;
    align-content: space-between;
    min-height: 560px;
    padding: 28px;
    border-radius: var(--radius-xl);
  }

  .orb {
    display: grid;
    place-items: center;
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    color: rgba(255, 255, 255, 0.95);
    background:
      radial-gradient(circle at 35% 24%, rgba(255, 255, 255, 0.7), transparent 28%),
      linear-gradient(145deg, #c73931, #6e1714);
    font-family: "STXingkai", "KaiTi", "Noto Serif SC", serif;
    font-size: clamp(96px, 14vw, 156px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.55),
      0 28px 70px rgba(104, 24, 20, 0.24);
  }

  .portrait p {
    margin: 26px 0 0;
    color: var(--muted);
    font-size: 14px;
    font-weight: 700;
    text-align: center;
  }

  @media (max-width: 940px) {
    .hero {
      grid-template-columns: 1fr;
      padding-top: 46px;
    }

    .hero-card,
    .portrait {
      min-height: auto;
    }

    .portrait {
      grid-template-columns: 120px 1fr;
      align-items: center;
      gap: 20px;
    }
  }

  @media (max-width: 560px) {
    .hero-card {
      padding: 28px;
      border-radius: 30px;
    }

    .hero-meta {
      margin-bottom: 38px;
    }

    .hero-actions a {
      width: 100%;
    }
  }
</style>
