---
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const navItems = [
  { label: "Research", href: `${base}research/` },
  { label: "Life", href: `${base}life/` },
  { label: "Works", href: `${base}works/` },
  { label: "Archive", href: `${base}archive/` },
];
---

<header class="header page-shell glass">
  <a class="brand" href={base} aria-label="珲 home">
    <span class="brand-mark">珲</span>
    <span class="brand-copy">
      <strong>Hui</strong>
      <small>In AI Era</small>
    </span>
  </a>
  <nav class="nav" aria-label="Primary navigation">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 16px;
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 74px;
    margin-top: 18px;
    padding: 12px 16px;
    border-radius: var(--radius-pill);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-width: max-content;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    color: #fff7ee;
    background:
      radial-gradient(circle at 32% 20%, rgba(255, 255, 255, 0.34), transparent 34%),
      linear-gradient(145deg, #c7372d, #851c18);
    font-family: "STXingkai", "KaiTi", "Noto Serif SC", serif;
    font-size: 28px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.38),
      0 12px 24px rgba(132, 28, 24, 0.22);
  }

  .brand-copy {
    display: grid;
    gap: 1px;
  }

  .brand-copy strong {
    font-size: 15px;
    line-height: 1.1;
  }

  .brand-copy small {
    color: var(--muted);
    font-size: 12px;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 6px;
  }

  .nav a {
    min-height: 40px;
    padding: 10px 15px;
    border-radius: var(--radius-pill);
    color: rgba(17, 19, 23, 0.7);
    font-size: 14px;
    font-weight: 650;
    transition:
      background 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .nav a:hover {
    color: var(--ink);
    background: rgba(255, 255, 255, 0.64);
    transform: translateY(-1px);
  }

  @media (max-width: 760px) {
    .header {
      position: static;
      align-items: flex-start;
      flex-direction: column;
      border-radius: 30px;
    }

    .nav {
      justify-content: flex-start;
    }

    .nav a {
      padding-inline: 12px;
    }
  }
</style>
